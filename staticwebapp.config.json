{
  "routes": [
    {
      "route": "/logged-out.html",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=ORIGINAL_URL",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "Cache-Control": "no-store"
  },
  "navigationFallback": {
    "rewrite": "/index.html"
  }
}
